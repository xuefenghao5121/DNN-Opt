+/// Drop-in replacement for extended_sgemm() that dispatches to DNN-Opt.
+///
+/// extended_sgemm uses Fortran/column-major convention:
+///   C(M×N, col-major, ldc) = alpha * op(A) * op(B) + beta * C
+///
+/// We convert to row-major using the standard duality:
+///   ColMajor(trA, trB, M, N, K, A, lda, B, ldb, C, ldc)
+///   = RowMajor(trB, trA, N, M, K, B, ldb, A, lda, C, ldc)
+inline dnnl_status_t dnnopt_sgemm(const char *transa, const char *transb,
+        const dim_t *M, const dim_t *N, const dim_t *K, const float *alpha,
+        const float *A, const dim_t *lda, const float *B, const dim_t *ldb,
+        const float *beta, float *C, const dim_t *ldc,
+        const float *bias) {
+    // Packed formats not supported by DNN-Opt
+    if (utils::one_of(*transa, 'P', 'p') || utils::one_of(*transb, 'P', 'p'))
+        return dnnl_unimplemented;
+
+    // Early exit
+    if (*M == 0 || *N == 0) return dnnl_success;
+    if (*K == 0) {
+        if (*beta == 0.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                std::memset(C + j * (*ldc), 0, *M * sizeof(float));
+        } else if (*beta != 1.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] *= *beta;
+        }
+        if (bias)
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] += bias[i];
+        return dnnl_success;
+    }
+
+    bool tA = (*transa == 'T' || *transa == 't');
+    bool tB = (*transb == 'T' || *transb == 't');
+
+    // Col-major to row-major duality:
+    //   ColMajor(trA, trB, M, N, K, A, lda, B, ldb, C, ldc)
+    //   = RowMajor(trB, trA, N, M, K, B, ldb, A, lda, C, ldc)
+    //
+    // After the duality, the row-major GEMM has rm_M=N, rm_N=M.
+    // C is used with the same ldc as the col-major convention.
+    // Normally ldc >= M (col-major) and we need ldc >= rm_N = M, so it's fine.
+    //
+    // However, dnnl_sgemm() pre-swaps M↔N before calling extended_sgemm(),
+    // so we may receive M_here > ldc. In that case, rm_N = M_here > ldc,
+    // which would cause the row-major GEMM to write beyond row boundaries.
+    // We handle this with a temporary buffer.
+    int rm_M = (int)*N;
+    int rm_N = (int)*M;
+    int rm_K = (int)*K;
+
+    if ((int)*ldc >= rm_N) {
+        // Normal path: ldc is adequate for row-major layout
+        dnnopt_gemm_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                B, (int)*ldb, A, (int)*lda,
+                *beta, C, (int)*ldc);
+    } else {
+        // ldc < rm_N: use temporary buffer with adequate stride
+        int safe_ldc = rm_N;
+        auto tmp = dnnopt::aligned_array<float>((size_t)rm_M * safe_ldc);
+
+        // Copy existing C from col-major layout to row-major tmp
+        // Col-major C(M_col × N_col, ldc): element (i,j) at C[j*ldc + i]
+        // Row-major tmp(rm_M × rm_N, safe_ldc): element (r,c) at tmp[r*safe_ldc + c]
+        // Mapping: row r corresponds to col-major column j (r=j, c=i)
+        if (*beta != 0.0f) {
+            for (int r = 0; r < rm_M; r++)
+                for (int c = 0; c < rm_N; c++)
+                    tmp[r * safe_ldc + c] = C[r * (int)*ldc + c];
+        }
+
+        dnnopt_gemm_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                B, (int)*ldb, A, (int)*lda,
+                *beta, tmp.get(), safe_ldc);
+
+        // Copy back: row-major tmp to col-major C
+        for (int r = 0; r < rm_M; r++)
+            for (int c = 0; c < rm_N; c++)
+                C[r * (int)*ldc + c] = tmp[r * safe_ldc + c];
+    }
+
+    // Apply bias: C[i,j] += bias[i] for all j (column-major)
+    if (bias) {
+        parallel_nd(*N, [&](dim_t j) {
+            float *c_col = C + j * (*ldc);
+            for (dim_t i = 0; i < *M; i++)
+                c_col[i] += bias[i];
+        });
+    }
+
+    return dnnl_success;
+}
+
+/// Drop-in replacement for gemm_bf16bf16f32() that dispatches to DNN-Opt.
+///
+/// gemm_bf16bf16f32 uses Fortran/column-major convention:
+///   C(M×N, col-major, ldc) = alpha * op(A) * op(B) + beta * C
+///   where A and B are bfloat16 matrices.
+///
+/// Same column-major to row-major duality as dnnopt_sgemm.
+inline dnnl_status_t dnnopt_gemm_bf16bf16f32(const char *transa, const char *transb,
+        const dim_t *M, const dim_t *N, const dim_t *K, const float *alpha,
+        const bfloat16_t *A, const dim_t *lda, const bfloat16_t *B, const dim_t *ldb,
+        const float *beta, float *C, const dim_t *ldc) {
+    // Early exit
+    if (*M == 0 || *N == 0) return dnnl_success;
+    if (*K == 0) {
+        if (*beta == 0.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                std::memset(C + j * (*ldc), 0, *M * sizeof(float));
+        } else if (*beta != 1.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] *= *beta;
+        }
+        return dnnl_success;
+    }
+
+    bool tA = (*transa == 'T' || *transa == 't');
+    bool tB = (*transb == 'T' || *transb == 't');
+
+    // Col-major to row-major duality (same as FP32):
+    //   ColMajor(trA, trB, M, N, K, A, lda, B, ldb, C, ldc)
+    //   = RowMajor(trB, trA, N, M, K, B, ldb, A, lda, C, ldc)
+    int rm_M = (int)*N;
+    int rm_N = (int)*M;
+    int rm_K = (int)*K;
+
+    // Cast oneDNN bfloat16_t* to dnnopt::bfloat16_t*
+    // Both have identical layout (uint16_t raw_bits/raw_bits_)
+    const dnnopt::bfloat16_t *A_dnnopt = reinterpret_cast<const dnnopt::bfloat16_t*>(A);
+    const dnnopt::bfloat16_t *B_dnnopt = reinterpret_cast<const dnnopt::bfloat16_t*>(B);
+
+    if ((int)*ldc >= rm_N) {
+        dnnopt_gemm_bf16_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                B_dnnopt, (int)*ldb, A_dnnopt, (int)*lda,
+                *beta, C, (int)*ldc);
+    } else {
+        int safe_ldc = rm_N;
+        auto tmp = dnnopt::aligned_array<float>((size_t)rm_M * safe_ldc);
+
+        if (*beta != 0.0f) {
+            for (int r = 0; r < rm_M; r++)
+                for (int c = 0; c < rm_N; c++)
+                    tmp[r * safe_ldc + c] = C[r * (int)*ldc + c];
+        }
+
+        dnnopt_gemm_bf16_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                B_dnnopt, (int)*ldb, A_dnnopt, (int)*lda,
+                *beta, tmp.get(), safe_ldc);
+
+        for (int r = 0; r < rm_M; r++)
+            for (int c = 0; c < rm_N; c++)
+                C[r * (int)*ldc + c] = tmp[r * safe_ldc + c];
+    }
+
+    return dnnl_success;
+}

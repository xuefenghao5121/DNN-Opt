+// DNN-Opt shape detection: determines if DNN-Opt should be used
+// for the given matmul shape instead of brgemm kernel.
+// DNN-Opt excels at: small M, irregular shapes, very small total ops.
+inline bool should_use_dnnopt_shape(dim_t M, dim_t N, dim_t K) {
+    if (M <= 0 || N <= 0 || K <= 0) return false;
+
+    // DNN-Opt sweet spots based on benchmarking:
+    // - Small M (tiny/small_m_wide kernels): M <= 16
+    // - Small square-ish: M <= 32, N <= 128, K <= 128
+    // - Very small total ops: M*N*K < 32768 (16K ops threshold)
+    // - Irregular M: non-power-of-2 and M <= 64
+
+    if (M <= 16) return true;
+    if (M <= 32 && N <= 128 && K <= 128) return true;
+    if (M * N * K < 32768) return true;
+
+    // Irregular: prime or non-power-of-2 small M
+    // DNN-Opt handles padding better for these
+    if (M <= 64 && !math::is_pow2(M)) return true;
+
+    return false;
+}

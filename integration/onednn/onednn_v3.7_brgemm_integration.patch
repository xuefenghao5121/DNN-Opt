+// DNN-Opt integration implementation
+template <cpu_isa_t isa>
+bool brgemm_matmul_t<isa>::should_use_dnnopt() const {
+    return pd()->get_brgemm_matmul_conf().use_dnnopt;
+}
+
+template <cpu_isa_t isa>
+status_t brgemm_matmul_t<isa>::execute_dnnopt(const exec_ctx_t &ctx) const {
+#ifdef DNNL_USE_DNNOPT
+    const float *src = reinterpret_cast<const float *>(
+            CTX_IN_MEM(const char *, DNNL_ARG_SRC));
+    const float *weights = reinterpret_cast<const float *>(
+            CTX_IN_MEM(const char *, DNNL_ARG_WEIGHTS));
+    float *dst = reinterpret_cast<float *>(
+            CTX_OUT_MEM(char *, DNNL_ARG_DST));
+
+    const auto &bgmmc = pd()->get_brgemm_matmul_conf();
+    const dim_t M = bgmmc.M;
+    const dim_t N = bgmmc.N;
+    const dim_t K = bgmmc.K;
+
+    // Get strides - assuming plain row-major layout for DNN-Opt path
+    // For more complex layouts, we may need additional handling
+    const dim_t lda = bgmmc.A_strides[0] / bgmmc.a_dt_sz;
+    const dim_t ldb = bgmmc.B_strides[0] / bgmmc.b_dt_sz;
+    const dim_t ldc = bgmmc.C_strides[0] / bgmmc.c_dt_sz;
+
+    // Handle batch dimension
+    const dim_t batch = bgmmc.batch;
+
+    for (dim_t b = 0; b < batch; b++) {
+        const float *A_batch = src + b * bgmmc.A_strides[2] / bgmmc.a_dt_sz;
+        const float *B_batch = weights + b * bgmmc.B_strides[2] / bgmmc.b_dt_sz;
+        float *C_batch = dst + b * bgmmc.C_strides[2] / bgmmc.c_dt_sz;
+
+        // Call DNN-Opt GEMM (row-major)
+        // DNN-Opt expects: A(M×K) × B(K×N) = C(M×N)
+        dnnopt::gemm_fp32(static_cast<int>(M), static_cast<int>(N),
+                          static_cast<int>(K), 1.0f, A_batch,
+                          static_cast<int>(lda), B_batch,
+                          static_cast<int>(ldb), 0.0f, C_batch,
+                          static_cast<int>(ldc));
+    }
+
+    return status::success;
+#else
+    return status::unimplemented;
+#endif
+}

+// Fast NEON-accelerated transpose: dst[cols, rows] = src[rows, cols]^T
+// Both src and dst are row-major. dst has ld_dst >= rows (columns of output).
+inline void neon_transpose_f32(const float *src, float *dst,
+        int rows, int cols, int ld_src, int ld_dst) {
+    int r = 0;
+#ifdef __ARM_NEON
+    for (; r + 3 < rows; r += 4) {
+        int c = 0;
+        for (; c + 3 < cols; c += 4) {
+            float32x4_t r0 = vld1q_f32(src + (r + 0) * ld_src + c);
+            float32x4_t r1 = vld1q_f32(src + (r + 1) * ld_src + c);
+            float32x4_t r2 = vld1q_f32(src + (r + 2) * ld_src + c);
+            float32x4_t r3 = vld1q_f32(src + (r + 3) * ld_src + c);
+            float32x4x2_t t01 = vzipq_f32(r0, r2);
+            float32x4x2_t t23 = vzipq_f32(r1, r3);
+            float32x4x2_t u0 = vzipq_f32(t01.val[0], t23.val[0]);
+            float32x4x2_t u1 = vzipq_f32(t01.val[1], t23.val[1]);
+            vst1q_f32(dst + (c + 0) * ld_dst + r, u0.val[0]);
+            vst1q_f32(dst + (c + 1) * ld_dst + r, u0.val[1]);
+            vst1q_f32(dst + (c + 2) * ld_dst + r, u1.val[0]);
+            vst1q_f32(dst + (c + 3) * ld_dst + r, u1.val[1]);
+        }
+        for (; c < cols; ++c)
+            for (int rr = r; rr < r + 4; ++rr)
+                dst[c * ld_dst + rr] = src[rr * ld_src + c];
+    }
+#endif
+    for (; r < rows; ++r)
+        for (int c = 0; c < cols; ++c)
+            dst[c * ld_dst + r] = src[r * ld_src + c];
+}
+
+// Minimum stride for DNN-Opt GEMM micro-kernel output.
+// The kernel writes full tiles (e.g., 8x12), so ldc must be >= tile_n.
+static constexpr int DNNOPT_MIN_LDC = 12;
+
+// Safe wrapper around dnnopt::gemm_fp32 that handles small ldc.
+// When ldc < DNNOPT_MIN_LDC, uses a temporary output buffer with adequate
+// stride, then copies the result back.
+inline void safe_gemm_fp32(int M, int N, int K, float alpha,
+        const float *A, int lda, const float *B, int ldb,
+        float beta, float *C, int ldc) {
+    if (N >= DNNOPT_MIN_LDC || ldc >= DNNOPT_MIN_LDC) {
+        // Normal path: stride is large enough for the kernel tile
+        dnnopt::gemm_fp32(M, N, K, alpha, A, lda, B, ldb, beta, C, ldc);
+    } else {
+        // Small N: use temporary buffer with safe stride
+        int safe_ldc = DNNOPT_MIN_LDC;
+        auto tmp = dnnopt::aligned_array<float>((size_t)M * safe_ldc);
+
+        // Copy existing C to tmp (for beta != 0)
+        if (beta != 0.0f) {
+            for (int i = 0; i < M; i++)
+                for (int j = 0; j < N; j++)
+                    tmp[i * safe_ldc + j] = C[i * ldc + j];
+        }
+
+        dnnopt::gemm_fp32(M, N, K, alpha, A, lda, B, ldb, beta, tmp.get(), safe_ldc);
+
+        // Copy result back to C
+        for (int i = 0; i < M; i++)
+            for (int j = 0; j < N; j++)
+                C[i * ldc + j] = tmp[i * safe_ldc + j];
+    }
+}
+
+// Row-major GEMM with proper handling of duality-transformed column-major data.
+//
+// Key insight: The duality transform already handles implicit transpose!
+//   ColMajor('N', 'N', M, N, K, A, B, C) = RowMajor('N', 'N', N, M, K, B, A, C)
+//
+// After duality:
+// - rm_M = N, rm_N = M, rm_K = K
+// - A_row = B_col (pointer swap)
+// - B_row = A_col (pointer swap)
+// - C_row = C_col (pointer swap)
+//
+// The column-major data read as row-major with same stride gives transpose:
+// - col-major X(rows×cols): element(r,c) at X[c*stride + r]
+// - read as row-major Y: Y[r*stride + c] = X[r*stride + c] = element(c,r) of X
+// - So row-major view = transpose of col-major view
+//
+// This implicit transpose exactly matches what duality needs!
+// For 'N' 'N' case: A_row = B_col^T, B_row = A_col^T (duality requirement satisfied)
+//
+// We only need to create temp buffers when stride requirements are not met:
+// - Row-major A(M×K) needs lda >= K
+// - Row-major B(K×N) needs ldb >= N
+// - Row-major C(M×N) needs ldc >= N
+//
+// transA/transB (from duality: transA=orig_transB, transB=orig_transA):
+// - For 'T' cases, the implicit transpose may not align, need special handling
+//
+// Row-major GEMM handling duality-transformed column-major data.
+//
+// IMPORTANT: For duality transform, col-major data read as row-major
+// gives implicit transpose which is exactly what we need!
+// - col-major X(rows×cols): element(r,c) at X[c*stride+r]
+// - read as row-major Y: Y[r*stride+c] = X[r*stride+c] = element(c,r) = X^T
+//
+// For 'N' 'N' case:
+// - A_rm = col-major B read as row-major = B^T (correct for duality!)
+// - B_rm = col-major A read as row-major = A^T (correct for duality!)
+// - C_rm = col-major C read as row-major = C^T (write back gives correct C)
+//
+// So we use input pointers directly, just check stride requirements.
+//
+inline void dnnopt_gemm_row_major(bool transA, bool transB,
+        int M, int N, int K, float alpha,
+        const float *A, int lda, const float *B, int ldb,
+        float beta, float *C, int ldc) {
+
+    // Row-major stride requirements:
+    // - A(M×K) needs lda >= K
+    // - B(K×N) needs ldb >= N
+    // - C(M×N) needs ldc >= N
+
+    // For implicit transpose to work, we also need:
+    // - col-major B has stride >= K (for A_rm = B^T)
+    // - col-major A has stride >= M (for B_rm = A^T)
+    // These are guaranteed by col-major constraints!
+
+    bool need_buf_A = (lda < K);
+    bool need_buf_B = (ldb < N);
+    bool need_buf_C = (ldc < N);
+
+    const float *A_ptr = A;
+    const float *B_ptr = B;
+    float *C_ptr = C;
+    int A_stride = lda;
+    int B_stride = ldb;
+    int C_stride = ldc;
+
+    auto A_buf = dnnopt::aligned_array<float>((size_t)M * K);
+    auto B_buf = dnnopt::aligned_array<float>((size_t)K * N);
+    auto C_buf = dnnopt::aligned_array<float>((size_t)M * N);
+
+    // If stride insufficient, create properly strided buffer
+    // For A: row-major A(M×K) needs stride >= K
+    if (need_buf_A) {
+        // Copy with proper stride: A_buf[i*K+j] = A[i*lda+j]
+        for (int i = 0; i < M; i++)
+            for (int j = 0; j < K; j++)
+                A_buf[i * K + j] = A[i * lda + j];  // NOT transpose, just fix stride
+        A_ptr = A_buf.get();
+        A_stride = K;
+    }
+
+    // For B: row-major B(K×N) needs stride >= N
+    if (need_buf_B) {
+        for (int i = 0; i < K; i++)
+            for (int j = 0; j < N; j++)
+                B_buf[i * N + j] = B[i * ldb + j];  // NOT transpose, just fix stride
+        B_ptr = B_buf.get();
+        B_stride = N;
+    }
+
+    // For C: row-major C(M×N) needs stride >= N
+    float beta_adj = beta;
+    if (need_buf_C) {
+        if (beta != 0.0f) {
+            for (int i = 0; i < M; i++)
+                for (int j = 0; j < N; j++)
+                    C_buf[i * N + j] = beta * C[i * ldc + j];  // NOT transpose
+        } else {
+            for (int i = 0; i < M * N; i++)
+                C_buf[i] = 0.0f;
+        }
+        C_ptr = C_buf.get();
+        C_stride = N;
+        beta_adj = 0.0f;
+    }
+
+    // Call dnnopt row-major GEMM
+    dnnopt::gemm_fp32(M, N, K, alpha, A_ptr, A_stride, B_ptr, B_stride, beta_adj, C_ptr, C_stride);
+
+    // Copy back C if we used temp buffer
+    if (need_buf_C) {
+        for (int i = 0; i < M; i++)
+            for (int j = 0; j < N; j++)
+                C[i * ldc + j] = C_buf[i * N + j];  // NOT transpose
+    }
+}
+
+} // anonymous namespace

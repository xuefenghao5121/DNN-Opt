+/// Drop-in replacement for extended_sgemm() that dispatches to DNN-Opt.
+///
+/// extended_sgemm uses Fortran/column-major convention:
+///   C(M×N, col-major, ldc) = alpha * op(A) * op(B) + beta * C
+///
+/// We convert to row-major using the standard duality:
+///   ColMajor(trA, trB, M, N, K, A, lda, B, ldb, C, ldc)
+///   = RowMajor(trB, trA, N, M, K, B, ldb, A, lda, C, ldc)
+inline dnnl_status_t dnnopt_sgemm(const char *transa, const char *transb,
+        const dim_t *M, const dim_t *N, const dim_t *K, const float *alpha,
+        const float *A, const dim_t *lda, const float *B, const dim_t *ldb,
+        const float *beta, float *C, const dim_t *ldc,
+        const float *bias) {
+    // Packed formats not supported by DNN-Opt
+    if (utils::one_of(*transa, 'P', 'p') || utils::one_of(*transb, 'P', 'p'))
+        return dnnl_unimplemented;
+
+    // Early exit
+    if (*M == 0 || *N == 0) return dnnl_success;
+    if (*K == 0) {
+        if (*beta == 0.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                std::memset(C + j * (*ldc), 0, *M * sizeof(float));
+        } else if (*beta != 1.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] *= *beta;
+        }
+        if (bias)
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] += bias[i];
+        return dnnl_success;
+    }
+
+    bool tA = (*transa == 'T' || *transa == 't');
+    bool tB = (*transb == 'T' || *transb == 't');
+
+    // Col-major to row-major duality:
+    // Original user col-major GEMM: C(M_user×N_user) = A(M_user×K) × B(K×N_user)
+    // = transpose version: C^T(N_user×M_user) = B^T(N_user×K) × A^T(K×M_user)
+    //
+    // dnnl_sgemm pre-swaps: extended_sgemm(M=N_user, N=M_user, A=B_user, B=A_user)
+    // So *M = N_user, *N = M_user, *A = B_user, *B = A_user
+    //
+    // Row-major GEMM for transpose version:
+    // C(rm_M×rm_N) = A(rm_M×rm_K) × B(rm_K×rm_N)
+    // where rm_M = N_user = *M, rm_N = M_user = *N, rm_K = K
+    // and A_rm = B_user (implicit transpose B^T), B_rm = A_user (implicit transpose A^T)
+    //
+    int rm_M = (int)*M;  // = N_user (for transpose version)
+    int rm_N = (int)*N;  // = M_user (for transpose version)
+    int rm_K = (int)*K;
+
+    // Row-major strides:
+    // A_rm needs stride >= K (but *lda is B_user's ldb which >= K ✓)
+    // B_rm needs stride >= N (but *ldb is A_user's lda which >= M_user, may < N_user)
+    // C_rm needs stride >= rm_N = M_user
+
+    if ((int)*ldc >= rm_N) {
+        // Normal path: ldc is adequate for row-major layout
+        // Row-major GEMM: C(rm_M×rm_N) = A_rm(rm_M×rm_K) × B_rm(rm_K×rm_N)
+        // A_rm = B_user (implicit transpose), B_rm = A_user (implicit transpose)
+        // So pass A=B_user (caller's A), B=A_user (caller's B)
+        dnnopt_gemm_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                A, (int)*lda, B, (int)*ldb,  // A=B_user, B=A_user
+                *beta, C, (int)*ldc);
+    } else {
+        // ldc < rm_N: use temporary buffer with adequate stride
+        int safe_ldc = rm_N;
+        auto tmp = dnnopt::aligned_array<float>((size_t)rm_M * safe_ldc);
+
+        // Copy existing C from col-major layout to row-major tmp
+        if (*beta != 0.0f) {
+            for (int r = 0; r < rm_M; r++)
+                for (int c = 0; c < rm_N; c++)
+                    tmp[r * safe_ldc + c] = C[r * (int)*ldc + c];
+        }
+
+        // Row-major GEMM: A_rm=B_user(caller's A), B_rm=A_user(caller's B)
+        dnnopt_gemm_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                A, (int)*lda, B, (int)*ldb,  // A=B_user, B=A_user
+                *beta, tmp.get(), safe_ldc);
+
+        // Copy back: row-major tmp to col-major C
+        for (int r = 0; r < rm_M; r++)
+            for (int c = 0; c < rm_N; c++)
+                C[r * (int)*ldc + c] = tmp[r * safe_ldc + c];
+    }
+
+    // Apply bias: C[i,j] += bias[i] for all j (column-major)
+    if (bias) {
+        parallel_nd(*N, [&](dim_t j) {
+            float *c_col = C + j * (*ldc);
+            for (dim_t i = 0; i < *M; i++)
+                c_col[i] += bias[i];
+        });
+    }
+
+    return dnnl_success;
+}
+
+} // namespace aarch64
+} // namespace cpu
+} // namespace impl
+} // namespace dnnl
+
+#endif // CPU_AARCH64_DNNOPT_GEMM_WRAPPER_HPP
